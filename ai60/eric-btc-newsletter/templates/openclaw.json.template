{
  "models": {
    "mode": "merge",
    "providers": {
      "{{model_provider_slug}}": {
        "baseUrl": "{{model_provider_url}}",
        "apiKey": "${{{MODEL_API_KEY_ENV}}}",
        "api": "openai-completions",
        "models": [
          {
            "id": "{{model_id}}",
            "name": "{{model_name}}"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "all",
        "scope": "agent",
        "workspaceAccess": "rw",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "readOnlyRoot": true,
          "network": "none",
          "memory": "1g",
          "cpus": 1,
          "pidsLimit": 256
        }
      }
    },
    "list": []
  },
  "bindings": [],
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 240
    }
  },
  "tools": {
    "profile": "messaging",
    "deny": [
      "group:automation",
      "group:runtime",
      "group:fs",
      "sessions_spawn"
    ],
    "fs": {
      "workspaceOnly": true
    },
    "exec": {
      "security": "allowlist",
      "ask": "on-miss",
      "allowlist": ["node", "npm", "curl", "jq"]
    },
    "elevated": {
      "enabled": false
    }
  },
  "cron": {
    "enabled": true
  },
  "channels": {},
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token"
    }
  },
  "logging": {
    "redactSensitive": "tools"
  }
}
