# =============================================================================
# OpenClaw Agent Environment Variables
# Copy this to ~/.openclaw/.env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Model Provider API Key
# Required: API key for your chosen model provider (OpenRouter, OpenAI, etc.)
# -----------------------------------------------------------------------------
MODEL_API_KEY=your-model-api-key-here

# -----------------------------------------------------------------------------
# GitHub Token
# Required for memory-sync and knowledge-sync scripts.
# Needs repo read/write access to the agent workspace repository.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your-github-token-here

# -----------------------------------------------------------------------------
# Channel Bot Tokens
# Add tokens for each channel your agent connects to.
# Uncomment and configure the channels you use.
# -----------------------------------------------------------------------------

# Discord
# DISCORD_BOT_TOKEN_AGENT1=your-discord-bot-token
# DISCORD_BOT_TOKEN_AGENT2=your-discord-bot-token
# DISCORD_GUILD_ID=your-discord-server-id

# Telegram
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Slack
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token

# -----------------------------------------------------------------------------
# Gateway Authentication
# Token used to authenticate with the OpenClaw gateway API.
# -----------------------------------------------------------------------------
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# -----------------------------------------------------------------------------
# Optional: Monitoring & Alerts
# -----------------------------------------------------------------------------
# ALERT_WEBHOOK_URL=https://hooks.example.com/your-webhook
# ALERT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Optional: Cloud Provider (for remote deployments)
# -----------------------------------------------------------------------------
# GCP_PROJECT_ID=your-gcp-project-id
# AWS_REGION=us-east-1
# DO_API_TOKEN=your-digitalocean-token
