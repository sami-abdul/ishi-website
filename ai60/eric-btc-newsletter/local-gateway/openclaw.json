{
  "models": {
    "mode": "merge",
    "providers": {
      "openai": {
        "provider": "openai",
        "model": "gpt-5.4",
        "role": "primary",
        "apiKeyEnv": "OPENAI_API_KEY",
        "maxTokens": 4096,
        "temperature": 0.7
      },
      "google": {
        "provider": "google",
        "model": "gemini-flash",
        "role": "fallback",
        "apiKeyEnv": "GOOGLE_API_KEY",
        "maxTokens": 4096,
        "temperature": 0.7
      }
    },
    "failover": {
      "enabled": true,
      "order": ["openai", "google"],
      "retries": 2,
      "backoffMs": 1000
    }
  },
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "all",
        "scope": "agent",
        "workspaceAccess": "rw",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "readOnlyRoot": true,
          "network": "none",
          "memory": "1g",
          "cpus": 1,
          "pidsLimit": 256
        }
      }
    },
    "list": [
      {
        "agentId": "eric",
        "agentDir": "~/.openclaw/agents/eric",
        "workspace": "~/.openclaw/agents/eric/workspace",
        "default": true,
        "tools": {
          "profile": "coding",
          "elevated": ["publish"]
        }
      }
    ]
  },
  "bindings": [
    {
      "channel": "discord",
      "accountId": "eric-bot",
      "agentId": "eric"
    }
  ],
  "session": {
    "dmScope": "per-channel-peer",
    "dailyReset": "04:00",
    "idleTimeoutMin": 120
  },
  "tools": {
    "security": "hardened",
    "policies": [
      {
        "action": "deny",
        "target": "group:automation"
      },
      {
        "action": "deny",
        "target": "group:runtime"
      },
      {
        "action": "deny",
        "target": "group:fs"
      },
      {
        "action": "deny",
        "target": "sessions_spawn"
      }
    ],
    "exec": {
      "allowlist": ["node", "npm", "curl", "jq", "bash"]
    },
    "capabilities": ["browser", "exec", "web_search", "cron"],
    "elevated": {
      "publish": {
        "description": "Publish newsletter to Beehiiv",
        "approvalRequired": true,
        "approvalGate": "operator"
      }
    }
  },
  "channels": {
    "discord": {
      "accountId": "eric-bot",
      "dm": {
        "policy": "allowlist"
      }
    }
  },
  "gateway": {
    "host": "127.0.0.1",
    "port": 18789,
    "auth": {
      "type": "token",
      "tokenEnv": "OPENCLAW_GATEWAY_TOKEN"
    }
  },
  "cron": {
    "enabled": true
  },
  "logging": {
    "redactSensitive": true
  }
}
