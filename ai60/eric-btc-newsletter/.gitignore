# =============================================================================
# Agent-Safe .gitignore
# =============================================================================

# Environment & Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account.json
.github_token

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Logs
logs/
*.log

# OS Files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Runtime
tmp/
temp/
.cache/

# OpenClaw
.openclaw/
openclaw-config/

# Docker
docker-compose.override.yml

# Build outputs
dist/
build/
out/
